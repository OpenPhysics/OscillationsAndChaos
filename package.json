{
  "name": "OscillationAndChaos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Collection of four classical mechanics simulations exploring oscillations and chaos: single spring, double spring, pendulum, and double pendulum.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenPhysics/OscillationsAndChaos.git"
  },
  "bugs": {
    "url": "https://github.com/OpenPhysics/OscillationsAndChaos/issues"
  },
  "homepage": "https://github.com/OpenPhysics/OscillationsAndChaos#readme",
  "keywords": [
    "oscillations-and-chaos",
    "simulation",
    "SceneryStack",
    "interactive",
    "physics",
    "classical mechanics",
    "pendulum",
    "chaos",
    "education",
    "pwa"
  ],
  "phet-io": {
    "validation": false,
    "compareDesignedAPIChanges": false
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "release": "npm version patch && git push && git push --tags",
    "check": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "icons": "tsx scripts/generate-icons.ts",
    "serve": "npx serve -s dist",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "katex": "^0.16.25",
    "scenerystack": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.10.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "lodash": "^4.18.0",
    "three": "^0.125.0",
    "picomatch": "^2.3.2"
  }
}
