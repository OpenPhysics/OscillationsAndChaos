{
  "name": "OscillationAndChaos",
  "private": true,
  "version": "0.0.0",
  "description": "Interactive Classical Mechanics Simulations using SceneryStack.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenPhysics/OscillationsAndChaos.git"
  },
  "bugs": {
    "url": "https://github.com/OpenPhysics/OscillationsAndChaos/issues"
  },
  "homepage": "https://github.com/OpenPhysics/OscillationsAndChaos#readme",
  "type": "module",
  "keywords": [
    "classical mechanics",
    "physics",
    "simulation",
    "SceneryStack",
    "interactive",
    "education",
    "double pendulum"
  ],
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "release": "npm version patch && git push && git push --tags",
    "check": "tsc --noEmit",
    "serve": "npx serve -s dist",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "katex": "^0.16.25",
    "scenerystack": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "phet-io": {
    "validation": false,
    "compareDesignedAPIChanges": false
  }
}
